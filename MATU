  <div class="footer-right">
    Built in Nairobi 🇰🇪<br>
    © 2025 MATU
  </div>
</footer>

<script>
  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach(r => observer.observe(r));

  // Waitlist
  let count = 247;
  function joinWaitlist() {
    const name = document.getElementById('wl-name').value.trim();
    const contact = document.getElementById('wl-contact').value.trim();
    if (!contact) {
      document.getElementById('wl-contact').style.borderColor = '#f87171';
      setTimeout(() => document.getElementById('wl-contact').style.borderColor = '', 1500);
      return;
    }
    count++;
    document.getElementById('wl-count').textContent = count;
    document.getElementById('wl-form').style.display = 'none';
    document.getElementById('success-msg').style.display = 'block';
  }
</script>
