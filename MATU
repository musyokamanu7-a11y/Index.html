<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MATU — Know Your Matatu</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --white: #f5f2ec;
    --yellow: #f5c518;
    --gray: #1a1a1a;
    --muted: #555;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 20px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(10,10,10,0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #1f1f1f;
  }

  .logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 22px;
    letter-spacing: -0.5px;
    color: var(--yellow);
  }

  .nav-cta {
    background: var(--yellow);
    color: var(--black);
    border: none;
    padding: 10px 20px;
    border-radius: 6px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 14px;
    cursor: pointer;
    text-decoration: none;
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 100px 24px 60px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(245,197,24,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-tag {
    display: inline-block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.2s forwards;
  }

  .hero h1 {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(42px, 10vw, 72px);
    line-height: 1.05;
    letter-spacing: -2px;
    margin-bottom: 24px;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.4s forwards;
  }

  .hero h1 span {
    color: var(--yellow);
  }

  .hero p {
    font-size: 17px;
    color: #aaa;
    max-width: 420px;
    line-height: 1.7;
    margin-bottom: 40px;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.6s forwards;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.6s ease 0.8s forwards;
  }

  .btn-primary {
    background: var(--yellow);
    color: var(--black);
    border: none;
    padding: 14px 28px;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 15px;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.2s, opacity 0.2s;
  }

  .btn-primary:hover { transform: translateY(-2px); opacity: 0.9; }

  .btn-ghost {
    background: transparent;
    color: var(--white);
    border: 1px solid #333;
    padding: 14px 28px;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 15px;
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .btn-ghost:hover { border-color: #666; }

  /* TICKER */
  .ticker {
    background: var(--yellow);
    color: var(--black);
    padding: 12px 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .ticker-inner {
    display: inline-block;
    animation: ticker 20s linear infinite;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1px;
  }

  .ticker-inner span { margin: 0 40px; }

  /* PROBLEM */
  .section {
    padding: 80px 24px;
  }

  .section-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 16px;
  }

  .section h2 {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(28px, 6vw, 44px);
    line-height: 1.1;
    letter-spacing: -1px;
    margin-bottom: 24px;
  }

  .section p {
    color: #aaa;
    font-size: 16px;
    max-width: 480px;
    line-height: 1.75;
  }

  /* PAIN POINTS */
  .pain-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 40px;
  }

  .pain-card {
    background: var(--gray);
    border: 1px solid #222;
    border-radius: 12px;
    padding: 24px 20px;
  }

  .pain-card .icon {
    font-size: 28px;
    margin-bottom: 12px;
  }

  .pain-card h3 {
    font-family: 'Syne', sans-serif;
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .pain-card p {
    font-size: 13px;
    color: #777;
    line-height: 1.6;
    max-width: 100%;
  }

  /* HOW IT WORKS */
  .how-section {
    padding: 80px 24px;
    background: var(--gray);
  }

  .steps {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .step {
    display: flex;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid #2a2a2a;
    align-items: flex-start;
  }

  .step:last-child { border-bottom: none; }

  .step-num {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 800;
    color: var(--yellow);
    min-width: 32px;
    padding-top: 2px;
  }

  .step-content h3 {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 17px;
    margin-bottom: 6px;
  }

  .step-content p {
    color: #777;
    font-size: 14px;
    line-height: 1.65;
    max-width: 400px;
  }

  /* ROUTES PREVIEW */
  .routes-section {
    padding: 80px 24px;
  }

  .route-list {
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .route-item {
    background: var(--gray);
    border: 1px solid #222;
    border-radius: 10px;
    padding: 16px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .route-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 15px;
  }

  .route-meta {
    font-size: 12px;
    color: #666;
    margin-top: 3px;
  }

  .route-badge {
    background: rgba(245,197,24,0.12);
    color: var(--yellow);
    font-size: 11px;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 20px;
    border: 1px solid rgba(245,197,24,0.2);
  }

  .route-badge.live {
    background: rgba(34,197,94,0.1);
    color: #4ade80;
    border-color: rgba(34,197,94,0.2);
  }

  .routes-note {
    margin-top: 20px;
    font-size: 13px;
    color: #555;
    font-style: italic;
  }

  /* WAITLIST */
  .waitlist-section {
    padding: 80px 24px;
    background: var(--gray);
    text-align: center;
  }

  .waitlist-section h2 {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(28px, 6vw, 44px);
    letter-spacing: -1px;
    margin-bottom: 12px;
  }

  .waitlist-section p {
    color: #777;
    font-size: 15px;
    margin-bottom: 36px;
  }

  .waitlist-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 400px;
    margin: 0 auto;
  }

  .waitlist-form input {
    background: #111;
    border: 1px solid #2a2a2a;
    color: var(--white);
    padding: 14px 18px;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    outline: none;
    transition: border-color 0.2s;
  }

  .waitlist-form input:focus { border-color: var(--yellow); }
  .waitlist-form input::placeholder { color: #444; }

  .waitlist-count {
    margin-top: 20px;
    font-size: 13px;
    color: #555;
  }

  .waitlist-count strong { color: var(--yellow); }

  /* SUCCESS STATE */
  .success-msg {
    display: none;
    background: rgba(34,197,94,0.1);
    border: 1px solid rgba(34,197,94,0.2);
    color: #4ade80;
    padding: 16px 20px;
    border-radius: 8px;
    font-size: 14px;
    text-align: center;
    max-width: 400px;
    margin: 0 auto;
  }

  /* INVESTOR */
  .investor-section {
    padding: 80px 24px;
    border-top: 1px solid #1a1a1a;
  }

  .investor-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 36px;
  }

  .stat-card {
    padding: 24px 20px;
    border: 1px solid #222;
    border-radius: 12px;
  }

  .stat-num {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 32px;
    color: var(--yellow);
    letter-spacing: -1px;
  }

  .stat-label {
    font-size: 13px;
    color: #666;
    margin-top: 4px;
    line-height: 1.4;
  }

  .investor-cta {
    margin-top: 40px;
    padding: 24px 20px;
    border: 1px solid #2a2a2a;
    border-radius: 12px;
    background: #111;
  }

  .investor-cta p {
    color: #888;
    font-size: 14px;
    margin-bottom: 16px;
    line-height: 1.65;
  }

  /* FOOTER */
  footer {
    padding: 40px 24px;
    border-top: 1px solid #1a1a1a;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: gap;
  }

  .footer-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 18px;
    color: var(--yellow);
  }

  .footer-text {
    font-size: 12px;
    color: #444;
    margin-top: 4px;
  }

  .footer-right {
    font-size: 12px;
    color: #333;
    text-align: right;
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
