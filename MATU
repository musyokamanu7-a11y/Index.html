</section>

<!-- WAITLIST -->
<section class="waitlist-section" id="waitlist">
  <div class="section-label reveal" style="text-align:center">Early Access</div>
  <h2 class="reveal">Be first on<br>the platform.</h2>
  <p class="reveal">Drop your number or email. We'll notify you the moment MATU goes live.</p>

